# ─────────────────────────────────────────────────────────────────────────────
# ANSI colours (no external deps)
# ─────────────────────────────────────────────────────────────────────────────

NO_COLOR = not sys.stdout.isatty() or os.environ.get("NO_COLOR")


def _c(*codes):
    if NO_COLOR:
        return ""
    return "\033[" + ";".join(str(c) for c in codes) + "m"


RST  = _c(0)
BOLD = _c(1)
DIM  = _c(2)
RED  = _c(31)
GRN  = _c(32)
YEL  = _c(33)
BLU  = _c(34)
MAG  = _c(35)
CYN  = _c(36)
BGRN = _c(92)
BYEL = _c(93)
BBLU = _c(94)
BMAG = _c(95)
BCYN = _c(96)
BWHT = _c(97)

LAYER_COLORS = [BCYN, BGRN, BYEL, BMAG, BBLU, BWHT]

