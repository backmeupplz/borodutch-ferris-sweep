#!/usr/bin/env python3
"""
sweep — Ferris Sweep keyboard layout manager

Commands:
  sweep show [LAYER]              Show layer diagram(s)
  sweep list                      List all layers
  sweep set LAYER ROW COL KEY     Set a specific key (ROW: 0-3, COL: 0-9/0-3)
  sweep note LAYER TEXT           Set description/notes for a layer
  sweep combos                    Show all combos
  sweep generate                  Generate QMK keymap files from layout.json
  sweep flash                     Compile + flash firmware (requires QMK CLI)
  sweep cheatsheet                Full scrollable cheat sheet (for Omarchy popup)
  sweep info                      Show project info and keyboard status
"""

