# -----------------------------------------------------------------------------
# Entry point
# -----------------------------------------------------------------------------

def main():
    p = argparse.ArgumentParser(
        prog="sweep",
        description="Ferris Sweep keyboard layout manager",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__.strip(),
    )
    sub = p.add_subparsers(dest="cmd", metavar="COMMAND")

    # list
    sub.add_parser("list", help="List all layers")

    # show
    sp = sub.add_parser("show", help="Show layer diagram(s)")
    sp.add_argument("layer", nargs="?", help="Layer name or index (omit for all)")

    # set
    sp = sub.add_parser("set", help="Set a specific key")
    sp.add_argument("layer",   help="Layer name or index")
    sp.add_argument("row",     help="Row (0=top 1=home 2=bottom 3=thumbs)")
    sp.add_argument("col",     help="Column (0-9 for alpha rows, 0-3 for thumbs)")
    sp.add_argument("keycode", help="QMK keycode (e.g. KC_ESC, LGUI_T(KC_A), LT(NAV,KC_SPC))")

    # note
    sp = sub.add_parser("note", help="Update a layer description")
    sp.add_argument("layer", help="Layer name or index")
    sp.add_argument("text",  help="New description text")

    # combos
    sub.add_parser("combos", help="Show all combos")

    # generate
    sub.add_parser("generate", help="Generate QMK keymap files from layout.json")

    # flash
    sub.add_parser("flash", help="Compile and flash firmware (requires QMK CLI)")

    # cheatsheet
    sub.add_parser("cheatsheet", help="Full cheat sheet (used by Omarchy popup)")

    # info
    sub.add_parser("info", help="Project info + keyboard connection status")

    args = p.parse_args()

    dispatch = {
        "list":       cmd_list,
        "show":       cmd_show,
        "set":        cmd_set,
        "note":       cmd_note,
        "combos":     cmd_combos,
        "generate":   cmd_generate,
        "flash":      cmd_flash,
        "cheatsheet": cmd_cheatsheet,
        "info":       cmd_info,
    }

    if args.cmd in dispatch:
        dispatch[args.cmd](args)
    else:
        p.print_help()


if __name__ == "__main__":
    main()
