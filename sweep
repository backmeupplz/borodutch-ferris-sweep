def _get_base_kc(kc):
    """Extract base keycode from mod-taps and layer-taps."""
    m = re.match(r"^(?:LGUI|RGUI|LALT|RALT|LCTL|RCTL|LSFT|RSFT)_T\((.+)\)$", kc)
    if m:
        return m.group(1).strip()
    m = re.match(r"^LT\(\w+,\s*(.+)\)$", kc)
    if m:
        return m.group(1).strip()
    return kc.strip()

MOD_SYM = {
    "LGUI": "Sup", "RGUI": "Sup",
    "LALT": "Alt", "RALT": "Alt",
    "LCTL": "Ctl", "RCTL": "Ctl",
    "LSFT": "Sft", "RSFT": "Sft",
}

MOD_LONG = {
    "LGUI": "Super", "RGUI": "Super",
    "LALT": "Alt",   "RALT": "Alt",
    "LCTL": "Ctrl",  "RCTL": "Ctrl",
    "LSFT": "Shift", "RSFT": "Shift",
}

# -----------------------------------------------------------------------------
# Key parser
# -----------------------------------------------------------------------------

def parse_key(kc: str) -> dict:
    """Parse any QMK keycode into {type, tap, sub}."""
    kc = kc.strip()

    if kc.strip("_") == "" or kc == "KC_TRNS":
        return {"type": "trans", "tap": "___", "sub": ""}
    if kc == "XXXXXXX":
        return {"type": "noop", "tap": "---", "sub": ""}

    # HRM: LGUI_T(KC_X)
    m = re.match(r"^(LGUI|RGUI|LALT|RALT|LCTL|RCTL|LSFT|RSFT)_T\((.+)\)$", kc)
    if m:
        mod, inner = m.groups()
        tap = KC.get(inner.strip(), inner.strip().replace("KC_", "")[:4])
        return {"type": "hrm", "tap": tap, "sub": MOD_SYM[mod]}

    # Layer-tap: LT(LAYER, KC_X)
    m = re.match(r"^LT\((\w+),\s*(.+)\)$", kc)
    if m:
        layer, inner = m.groups()
        tap = KC.get(inner.strip(), inner.strip().replace("KC_", "")[:4])
        return {"type": "lt", "tap": tap, "sub": layer[:3]}

    # One-shot mod: OSM(MOD_LSFT)
    m = re.match(r"^OSM\(MOD_(.+)\)$", kc)
    if m:
        mod = m.group(1)
        d = {"LSFT": "Sft", "RSFT": "Sft", "LCTL": "Ctl", "RCTL": "Ctl",
             "LALT": "Alt", "RALT": "Alt", "LGUI": "Sup",  "RGUI": "Sup"}
        return {"type": "osm", "tap": d.get(mod, mod[:3]), "sub": "1sh"}

    # Momentary layer: MO(LAYER)
    m = re.match(r"^MO\((\w+)\)$", kc)
    if m:
        return {"type": "mo", "tap": m.group(1)[:4], "sub": "hold"}

    # One-shot layer: OSL(LAYER)
    m = re.match(r"^OSL\((\w+)\)$", kc)
    if m:
        return {"type": "osl", "tap": m.group(1)[:3], "sub": "osl"}

    # Modifier wrapper: LGUI(KC_X), LSFT(KC_X), S(KC_X), etc.
    m = re.match(r"^(LGUI|RGUI|LALT|RALT|LCTL|RCTL|LSFT|RSFT|S)\((.+)\)$", kc)
    if m:
        # Check KC dict first for known display names (e.g. S(KC_P) -> ":")
        if kc in KC:
            return {"type": "basic", "tap": KC[kc], "sub": ""}
        mod, inner = m.groups()
        mod_names = {"LGUI": "Sup", "RGUI": "Sup", "LALT": "Alt", "RALT": "Alt",
                     "LCTL": "Ctl", "RCTL": "Ctl", "LSFT": "Sft", "RSFT": "Sft", "S": "Sft"}
        inner_disp = KC.get(inner.strip(), inner.strip().replace("KC_", "")[:4])
        mod_disp = mod_names.get(mod, mod[:3])
        return {"type": "basic", "tap": f"{mod_disp}+{inner_disp}", "sub": ""}

    # Basic
    disp = KC.get(kc, kc.replace("KC_", "")[:4])
    return {"type": "basic", "tap": disp, "sub": ""}


# -----------------------------------------------------------------------------
# Rendering helpers
# -----------------------------------------------------------------------------

KEY_W = 7   # visual width of each key cell (fits "Bsp/LO" etc)
HALF  = 5   # keys per hand

SEP = DIM + "|" + RST


def _ctr(s: str, w: int = KEY_W) -> str:
    """Center plain string in w chars (no ANSI)."""
    s = str(s)[:w]
    pad = w - len(s)
    return " " * (pad // 2) + s + " " * (pad - pad // 2)


def _is_trans(kc: str) -> bool:
    return kc.strip("_") == "" or kc == "KC_TRNS"


def _resolve_transparent(layers, layer_idx, row_idx, col_idx):
    """Resolve transparent key to the BASE layer (layer 0).

    With layer-tap activation, only the active layer + BASE are relevant.
    Other layers aren't in the stack, so we skip straight to BASE.
    """
    base = layers[0]["rows"]
    if row_idx < len(base) and col_idx < len(base[row_idx]):
        k = base[row_idx][col_idx]
        if not _is_trans(k):
            return k
    return "_______"


def _compact_key(kc: str, inherited: bool = False, ru_char: str = None) -> str:
    """Return a single colored string of width KEY_W showing tap/hold."""
    p = parse_key(kc)
    tap = p["tap"]
    sub = p["sub"]

    has_sub = sub and sub.strip()

    if has_sub:
        if ru_char:
            combined = f"{tap}{ru_char}/{sub}"
        else:
            combined = f"{tap}/{sub}"
    else:
        combined = tap

    # Inline Russian character (dim) next to the main label
    if ru_char and not has_sub:
        vis = f"{tap} {ru_char}"
        vis_len = len(vis)
        pad = KEY_W - vis_len
        lpad = pad // 2
        rpad = pad - lpad
        main = " " * lpad + tap
        ru_part = " " + ru_char
        trail = " " * rpad
        if inherited:
            return DIM + main + ru_part + trail + RST
        return main + DIM + ru_part + RST + trail

    if ru_char and has_sub:
        # e.g. "AФ/Sup" — dim the Russian char within the colored cell
        centered = _ctr(combined)
        # Split to colorize: tap in main color, ru dim, /sub in main color
        padded_vis = centered
        if inherited:
            return DIM + padded_vis + RST
        if p["type"] == "hrm":
            pre = _ctr(f"{tap}/{sub}")  # same width padding
            # Rebuild with dim Russian char inserted
            vis_with_ru = f"{tap}{ru_char}/{sub}"
            c = _ctr(vis_with_ru)
            # Find where ru_char sits to dim it
            idx = c.find(ru_char)
            return CYN + c[:idx] + RST + DIM + ru_char + RST + CYN + c[idx+len(ru_char):] + RST
        if p["type"] == "lt":
            vis_with_ru = f"{tap}{ru_char}/{sub}"
            c = _ctr(vis_with_ru)
            idx = c.find(ru_char)
            return BGRN + c[:idx] + RST + DIM + ru_char + RST + BGRN + c[idx+len(ru_char):] + RST
        return padded_vis

    centered = _ctr(combined)

    if inherited:
        return DIM + centered + RST
    if p["type"] == "hrm":
        return CYN + centered + RST
    if p["type"] == "lt":
        return BGRN + centered + RST
    if p["type"] == "trans":
        return DIM + centered + RST
    if p["type"] == "noop":
        return DIM + RED + centered + RST
    if p["type"] in ("osm", "osl", "mo"):
        return BMAG + centered + RST
    return centered


def _render_row(keys, inherited=None, ru_chars=None):
    if inherited is None:
        inherited = [False] * len(keys)
    if ru_chars is None:
        ru_chars = [None] * len(keys)
    left  = keys[:HALF]
    right = keys[HALF : HALF * 2]
    inh = inherited[:HALF] + inherited[HALF : HALF * 2]
    ru  = ru_chars[:HALF] + ru_chars[HALF : HALF * 2]
    all_keys = left + right
    cells = [_compact_key(k, inherited=i, ru_char=r) for k, i, r in zip(all_keys, inh, ru)]
    return " ".join(cells[:HALF]) + "  " + SEP + "  " + " ".join(cells[HALF:])


def _render_thumb(thumbs, inherited=None, ru_chars=None):
    if inherited is None:
        inherited = [False] * len(thumbs)
    if ru_chars is None:
        ru_chars = [None] * len(thumbs)
    left_t  = thumbs[:2]
    right_t = thumbs[2:4]
    inh = inherited[:2] + inherited[2:4]
    ru  = ru_chars[:2] + ru_chars[2:4]
    all_keys = left_t + right_t
    cells = [_compact_key(k, inherited=i, ru_char=r) for k, i, r in zip(all_keys, inh, ru)]
    # Align | with alpha rows
    # Alpha | is at: HALF*KEY_W + (HALF-1) + 2 = 5*7+4+2 = 41
    # Thumb before |: indent + 2*KEY_W + 1 + 2 = indent + 17
    alpha_sep_pos = HALF * KEY_W + (HALF - 1) + 2
    thumb_before_sep = 2 * KEY_W + 1 + 2
    indent = " " * (alpha_sep_pos - thumb_before_sep)
    return indent + " ".join(cells[:2]) + "  " + SEP + "  " + " ".join(cells[2:])


def _render_ru_subtitle(keys):
    """Render a dim Russian subtitle row under an alpha row."""
    cells = []
    for kc in keys:
        base = _get_base_kc(kc)
        ru = RU.get(base, "")
        cells.append(_ctr(ru) if ru else " " * KEY_W)
    left = " ".join(cells[:HALF])
    right = " ".join(cells[HALF:])
    return f"{DIM}{left}    {right}{RST}"


def render_layer(layer: dict, idx: int, total: int, layers=None) -> str:
    rows  = layer["rows"]
    name  = layer["name"]
    desc  = layer.get("description", "")
    color = LAYER_COLORS[idx % len(LAYER_COLORS)]
    W     = 61

    # Resolve transparent keys to the underlying key from layers below
    resolved_rows = []
    inherited_flags = []
    for ri, row in enumerate(rows):
        res_row = []
        inh_row = []
        for ci, k in enumerate(row):
            if _is_trans(k) and layers and idx > 0:
                resolved = _resolve_transparent(layers, idx, ri, ci)
                res_row.append(resolved)
                inh_row.append(True)
            else:
                res_row.append(k)
                inh_row.append(False)
        resolved_rows.append(res_row)
        inherited_flags.append(inh_row)

    out = []
    header = f"{color}{BOLD}{name}{RST} {DIM}{desc}{RST}"
    out.append(f"{color}{'-' * W}{RST}")
    out.append(f"  {header}")

    alpha_rows = resolved_rows[:3]
    alpha_inh  = inherited_flags[:3]
    thumbs     = resolved_rows[3] if len(resolved_rows) > 3 else []
    thumbs_inh = inherited_flags[3] if len(inherited_flags) > 3 else []

    is_base = name == "BASE"

    for i, row in enumerate(alpha_rows):
        orig_row = rows[i] if i < len(rows) else row
        ru_chars = [RU.get(_get_base_kc(k)) for k in orig_row]
        out.append(f"  {_render_row(row, alpha_inh[i], ru_chars=ru_chars)}")

    if thumbs:
        orig_thumbs = rows[3] if len(rows) > 3 else thumbs
        ru_chars = [RU.get(_get_base_kc(k)) for k in orig_thumbs]
        out.append(f"  {_render_thumb(thumbs, thumbs_inh, ru_chars=ru_chars)}")

    # HRM legend removed — Russian chars are now inline in HRM cells (e.g. AФ/Sup)

    return "\n".join(out)


# -----------------------------------------------------------------------------
# Layout I/O
# -----------------------------------------------------------------------------

def load() -> dict:
    if not LAYOUT_FILE.exists():
        sys.exit(f"layout.json not found at {LAYOUT_FILE}")
    with open(LAYOUT_FILE) as f:
        return json.load(f)


def save(layout: dict):
    with open(LAYOUT_FILE, "w") as f:
        json.dump(layout, f, indent=2)
    print(f"{GRN}✓{RST} layout.json saved — run {BOLD}sweep generate{RST} to update QMK files")


def find_layer(layout, ref) -> tuple:
    """Find layer by name or index. Returns (idx, layer)."""
    layers = layout["layers"]
    try:
        idx = int(ref)
        if 0 <= idx < len(layers):
            return idx, layers[idx]
    except (ValueError, TypeError):
        pass
    for i, lay in enumerate(layers):
        if lay["name"].upper() == str(ref).upper():
            return i, lay
    sys.exit(f"Layer '{ref}' not found. Use 'sweep list' to see available layers.")


