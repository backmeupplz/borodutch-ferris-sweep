# -----------------------------------------------------------------------------
# Key parser
# -----------------------------------------------------------------------------

def parse_key(kc: str) -> dict:
    """Parse any QMK keycode into {type, tap, sub}."""
    kc = kc.strip()

    if kc.strip("_") == "" or kc == "KC_TRNS":
        return {"type": "trans", "tap": "___", "sub": ""}
    if kc == "XXXXXXX":
        return {"type": "noop", "tap": "---", "sub": ""}

    # HRM: LGUI_T(KC_X)
    m = re.match(r"^(LGUI|RGUI|LALT|RALT|LCTL|RCTL|LSFT|RSFT)_T\((.+)\)$", kc)
    if m:
        mod, inner = m.groups()
        tap = KC.get(inner.strip(), inner.strip().replace("KC_", "")[:4])
        return {"type": "hrm", "tap": tap, "sub": MOD_SYM[mod]}

    # Layer-tap: LT(LAYER, KC_X)
    m = re.match(r"^LT\((\w+),\s*(.+)\)$", kc)
    if m:
        layer, inner = m.groups()
        tap = KC.get(inner.strip(), inner.strip().replace("KC_", "")[:4])
        return {"type": "lt", "tap": tap, "sub": layer[:3]}

    # One-shot mod: OSM(MOD_LSFT)
    m = re.match(r"^OSM\(MOD_(.+)\)$", kc)
    if m:
        mod = m.group(1)
        d = {"LSFT": "Sft", "RSFT": "Sft", "LCTL": "Ctl", "RCTL": "Ctl",
             "LALT": "Alt", "RALT": "Alt", "LGUI": "Sup",  "RGUI": "Sup"}
        return {"type": "osm", "tap": d.get(mod, mod[:3]), "sub": "1sh"}

    # Momentary layer: MO(LAYER)
    m = re.match(r"^MO\((\w+)\)$", kc)
    if m:
        return {"type": "mo", "tap": m.group(1)[:4], "sub": "hold"}

    # One-shot layer: OSL(LAYER)
    m = re.match(r"^OSL\((\w+)\)$", kc)
    if m:
        return {"type": "osl", "tap": m.group(1)[:3], "sub": "osl"}

    # Shifted key: S(KC_X)
    m = re.match(r"^S\((.+)\)$", kc)
    if m:
        disp = KC.get(kc, KC.get(m.group(1), m.group(1).replace("KC_", "")[:4]))
        return {"type": "basic", "tap": disp, "sub": ""}

    # Basic
    disp = KC.get(kc, kc.replace("KC_", "")[:4])
    return {"type": "basic", "tap": disp, "sub": ""}


# -----------------------------------------------------------------------------
# Rendering helpers
# -----------------------------------------------------------------------------

KEY_W = 7   # visual width of each key cell (fits "Bsp/LO" etc)
HALF  = 5   # keys per hand

SEP = DIM + "|" + RST


def _ctr(s: str, w: int = KEY_W) -> str:
    """Center plain string in w chars (no ANSI)."""
    s = str(s)[:w]
    pad = w - len(s)
    return " " * (pad // 2) + s + " " * (pad - pad // 2)


def _is_trans(kc: str) -> bool:
    return kc.strip("_") == "" or kc == "KC_TRNS"


def _resolve_transparent(layers, layer_idx, row_idx, col_idx):
    """Resolve transparent key to the BASE layer (layer 0).

    With layer-tap activation, only the active layer + BASE are relevant.
    Other layers aren't in the stack, so we skip straight to BASE.
    """
    base = layers[0]["rows"]
    if row_idx < len(base) and col_idx < len(base[row_idx]):
        k = base[row_idx][col_idx]
        if not _is_trans(k):
            return k
    return "_______"


def _compact_key(kc: str, inherited: bool = False) -> str:
    """Return a single colored string of width KEY_W showing tap/hold."""
    p = parse_key(kc)
    tap = p["tap"]
    sub = p["sub"]

    if sub and sub.strip():
        # Combine as "tap/sub" e.g. "Bsp/LOW"
        combined = f"{tap}/{sub}"
    else:
        combined = tap

    centered = _ctr(combined)

    if inherited:
        return DIM + centered + RST
    if p["type"] == "hrm":
        return CYN + centered + RST
    if p["type"] == "lt":
        return BGRN + centered + RST
    if p["type"] == "trans":
        return DIM + centered + RST
    if p["type"] == "noop":
        return DIM + RED + centered + RST
    if p["type"] in ("osm", "osl", "mo"):
        return BMAG + centered + RST
    return centered


def _render_row(keys, inherited=None):
    if inherited is None:
        inherited = [False] * len(keys)
    left  = keys[:HALF]
    right = keys[HALF : HALF * 2]
    inh = inherited[:HALF] + inherited[HALF : HALF * 2]
    all_keys = left + right
    cells = [_compact_key(k, inherited=i) for k, i in zip(all_keys, inh)]
    return " ".join(cells[:HALF]) + "  " + SEP + "  " + " ".join(cells[HALF:])


def _render_thumb(thumbs, inherited=None):
    if inherited is None:
        inherited = [False] * len(thumbs)
    left_t  = thumbs[:2]
    right_t = thumbs[2:4]
    inh = inherited[:2] + inherited[2:4]
    all_keys = left_t + right_t
    cells = [_compact_key(k, inherited=i) for k, i in zip(all_keys, inh)]
    # Align | with alpha rows
    # Alpha | is at: HALF*KEY_W + (HALF-1) + 2 = 5*7+4+2 = 41
    # Thumb before |: indent + 2*KEY_W + 1 + 2 = indent + 17
    alpha_sep_pos = HALF * KEY_W + (HALF - 1) + 2
    thumb_before_sep = 2 * KEY_W + 1 + 2
    indent = " " * (alpha_sep_pos - thumb_before_sep)
    return indent + " ".join(cells[:2]) + "  " + SEP + "  " + " ".join(cells[2:])


def render_layer(layer: dict, idx: int, total: int, layers=None) -> str:
    rows  = layer["rows"]
    name  = layer["name"]
    desc  = layer.get("description", "")
    color = LAYER_COLORS[idx % len(LAYER_COLORS)]
    W     = 61

    # Resolve transparent keys to the underlying key from layers below
    resolved_rows = []
    inherited_flags = []
    for ri, row in enumerate(rows):
        res_row = []
        inh_row = []
        for ci, k in enumerate(row):
            if _is_trans(k) and layers and idx > 0:
                resolved = _resolve_transparent(layers, idx, ri, ci)
                res_row.append(resolved)
                inh_row.append(True)
            else:
                res_row.append(k)
                inh_row.append(False)
        resolved_rows.append(res_row)
        inherited_flags.append(inh_row)

    out = []
    header = f"{color}{BOLD}{name}{RST} {DIM}{desc}{RST}"
    out.append(f"{color}{'-' * W}{RST}")
    out.append(f"  {header}")

    alpha_rows = resolved_rows[:3]
    alpha_inh  = inherited_flags[:3]
    thumbs     = resolved_rows[3] if len(resolved_rows) > 3 else []
    thumbs_inh = inherited_flags[3] if len(inherited_flags) > 3 else []

    for i, row in enumerate(alpha_rows):
        out.append(f"  {_render_row(row, alpha_inh[i])}")
        if i < len(alpha_rows) - 1:
            out.append("")

    if thumbs:
        out.append("")
        out.append(f"  {_render_thumb(thumbs, thumbs_inh)}")

    # HRM legend (inline, compact)
    home = rows[1] if len(rows) > 1 else []
    hrms = [(i, k) for i, k in enumerate(home) if "_T(" in k]
    if hrms:
        def _hrm_fmt(kc):
            m = re.match(r"^(LGUI|RGUI|LALT|RALT|LCTL|RCTL|LSFT|RSFT)_T\((.+)\)$", kc)
            if m:
                mod, inner = m.groups()
                letter = KC.get(inner.strip(), inner.strip().replace("KC_", ""))
                return f"{CYN}{letter}{RST}={YEL}{MOD_LONG[mod]}{RST}"
            return kc
        hrm_parts = [_hrm_fmt(k) for _, k in hrms]
        out.append(f"  {DIM}hold:{RST} " + "  ".join(hrm_parts))

    # Notes
    notes = layer.get("notes", [])
    for note in notes:
        out.append(f"  {DIM}* {note}{RST}")

    return "\n".join(out)


# -----------------------------------------------------------------------------
# Layout I/O
# -----------------------------------------------------------------------------

def load() -> dict:
    if not LAYOUT_FILE.exists():
        sys.exit(f"layout.json not found at {LAYOUT_FILE}")
    with open(LAYOUT_FILE) as f:
        return json.load(f)


def save(layout: dict):
    with open(LAYOUT_FILE, "w") as f:
        json.dump(layout, f, indent=2)
    print(f"{GRN}✓{RST} layout.json saved — run {BOLD}sweep generate{RST} to update QMK files")


def find_layer(layout, ref) -> tuple:
    """Find layer by name or index. Returns (idx, layer)."""
    layers = layout["layers"]
    try:
        idx = int(ref)
        if 0 <= idx < len(layers):
            return idx, layers[idx]
    except (ValueError, TypeError):
        pass
    for i, lay in enumerate(layers):
        if lay["name"].upper() == str(ref).upper():
            return i, lay
    sys.exit(f"Layer '{ref}' not found. Use 'sweep list' to see available layers.")


# -----------------------------------------------------------------------------
# QMK code generation
# -----------------------------------------------------------------------------

def generate_keymap(layout: dict):
    """Generate keymap/ directory files from layout.json."""
    KEYMAP_DIR.mkdir(exist_ok=True)

    layers  = layout["layers"]
    combos  = layout.get("combos", [])
    cfg     = layout.get("config", {})
    ko_list = layout.get("key_overrides", [])

    enum_names = [l["name"] for l in layers]

    # -- keymap.c --------------------------------------------------------------
    kc_lines = [
        "// AUTO-GENERATED by sweep — edit layout.json then run: sweep generate",
        "#include QMK_KEYBOARD_H",
        '#include "users/holykeebs/holykeebs.h"',
        "",
        "// --- Layer indices --------------------------------------------------",
        "enum layers {",
    ]
    for name in enum_names:
        kc_lines.append(f"    {name},")
    kc_lines.append("};")
    kc_lines.append("")

    # Combo declarations
    if combos:
        kc_lines.append("// --- Combos ---------------------------------------------------------")
        for c in combos:
            keys_str = ", ".join(c["keys"]) + ", COMBO_END"
            kc_lines.append(f'const uint16_t PROGMEM {c["name"]}[] = {{{keys_str}}};')
        kc_lines.append("")
        kc_lines.append("combo_t key_combos[] = {")
        for c in combos:
            desc = c.get("description", "")
            kc_lines.append(f'    COMBO({c["name"]}, {c["result"]}),  // {desc}')
        kc_lines.append("};")
        kc_lines.append("")

    # Key overrides
    if ko_list:
        kc_lines.append("// --- Key overrides --------------------------------------------------")
        for ko in ko_list:
            var  = re.sub(r"[^a-z0-9]", "_", ko["trigger"].lower()) + "_ko"
            desc = ko.get("description", "")
            kc_lines.append(f'const key_override_t {var} = ko_make_basic({ko["modifier"]}, {ko["trigger"]}, {ko["result"]});  // {desc}')
        kc_lines.append("")
        kc_lines.append("const key_override_t *key_overrides[] = {")
        for ko in ko_list:
            var = re.sub(r"[^a-z0-9]", "_", ko["trigger"].lower()) + "_ko"
            kc_lines.append(f"    &{var},")
        kc_lines.append("    NULL")
        kc_lines.append("};")
        kc_lines.append("")

    # Keymaps
    kc_lines.append("// --- Keymaps --------------------------------------------------------")
    kc_lines.append("const uint16_t PROGMEM keymaps[][MATRIX_ROWS][MATRIX_COLS] = {")
    kc_lines.append("")
    lmacro = layout["meta"]["layout_macro"]

    for lay in layers:
        name = lay["name"]
        rows = lay["rows"]
        flat = []
        for row in rows:
            flat.extend(row)
        kc_lines.append(f"[{name}] = {lmacro}(")
        # Format in rows of 10 (alpha) then 4 (thumbs)
        alpha = flat[:30]
        thumbs = flat[30:]
        for i in range(0, 30, 10):
            row_keys = alpha[i:i+10]
            sep = "," if (i < 20 or thumbs) else ""
            kc_lines.append("    " + ", ".join(row_keys) + ("," if i < 20 else ("," if thumbs else "")))
        if thumbs:
            kc_lines.append("    " + ", ".join(thumbs))
        kc_lines.append("),")
        kc_lines.append("")

    kc_lines.append("};")
    kc_lines.append("")

    # Per-key tapping term
    hrm_keys = []
    for lay in layers:
        if lay["name"] == "BASE":
            for row in lay["rows"][:3]:
                for kc in row:
                    m = re.match(r"^(LGUI|RGUI|LALT|RALT|LCTL|RCTL|LSFT|RSFT)_T\((.+)\)$", kc)
                    if m:
                        mod, inner = m.groups()
                        hrm_keys.append((kc, mod, inner))
            break

    if hrm_keys:
        tt = cfg.get('tapping_term', 200)
        kc_lines.append("// --- Per-key tapping term -------------------------------------------")
        kc_lines.append("uint16_t get_tapping_term(uint16_t keycode, keyrecord_t *record) {")
        kc_lines.append("    switch (keycode) {")
        pinky = [k for k in hrm_keys if k[1] in ("LGUI", "RGUI")]
        ring  = [k for k in hrm_keys if k[1] in ("LALT", "RALT")]
        index = [k for k in hrm_keys if k[1] in ("LSFT", "RSFT")]
        if pinky:
            for kc, _, _ in pinky:
                kc_lines.append(f"        case {kc}:  // pinky — slowest")
            kc_lines.append(f"            return TAPPING_TERM + 30;  // {tt + 30}ms")
        if ring:
            for kc, _, _ in ring:
                kc_lines.append(f"        case {kc}:  // ring — slow")
            kc_lines.append(f"            return TAPPING_TERM + 15;  // {tt + 15}ms")
        if index:
            for kc, _, _ in index:
                kc_lines.append(f"        case {kc}:  // index — fastest")
            kc_lines.append(f"            return TAPPING_TERM - 20;  // {tt - 20}ms")
        kc_lines.append("        default:")
        kc_lines.append("            return TAPPING_TERM;")
        kc_lines.append("    }")
        kc_lines.append("}")
        kc_lines.append("")

    (KEYMAP_DIR / "keymap.c").write_text("\n".join(kc_lines))

    # -- config.h --------------------------------------------------------------
    tt  = cfg.get("tapping_term", 200)
    qtt = cfg.get("quick_tap_term", 0)
    ct  = cfg.get("combo_term", 50)

    config_h = f"""\
// AUTO-GENERATED by sweep — edit layout.json then run: sweep generate
#pragma once

// Tapping term — start at {tt}ms, tune ±25ms if HRMs misfire / feel sluggish
#define TAPPING_TERM {tt}

// Zero QUICK_TAP disables double-tap auto-repeat (prevents "aaaa" HRM misfires)
#define QUICK_TAP_TERM {qtt}

// Combo detection window
#define COMBO_TERM {ct}

// VIA support: allow all 6 layers
#define DYNAMIC_KEYMAP_LAYER_COUNT 6

// DO NOT enable HOLD_ON_OTHER_KEY_PRESS — destroys HRM usability
// DO NOT enable PERMISSIVE_HOLD globally — causes misfires on key rolls

// Split serial pin for the GP0 rewire
#define SERIAL_USART_TX_PIN GP0
"""
    (KEYMAP_DIR / "config.h").write_text(config_h)

    # -- rules.mk --------------------------------------------------------------
    # Auto-detect mouse keys across all layers
    has_mouse = False
    for lay in layers:
        for row in lay["rows"]:
            for k in row:
                if any(prefix in k for prefix in ("KC_MS_", "MS_", "KC_WH_", "WH_")):
                    has_mouse = True
                    break
            if has_mouse:
                break
        if has_mouse:
            break

    rules_mk_lines = [
        "# AUTO-GENERATED by sweep — edit layout.json then run: sweep generate",
        "",
        "COMBO_ENABLE        = yes",
        "CAPS_WORD_ENABLE    = yes",
        "VIA_ENABLE          = yes",
    ]
    if has_mouse:
        rules_mk_lines.append("MOUSEKEY_ENABLE     = yes")
    if ko_list:
        rules_mk_lines.append("KEY_OVERRIDE_ENABLE = yes")
    rules_mk_lines += [
        "",
        "# Optional — enable if needed:",
        "# TAP_DANCE_ENABLE  = yes   # adds tapping_term latency per key — avoid unless needed",
    ]
    (KEYMAP_DIR / "rules.mk").write_text("\n".join(rules_mk_lines) + "\n")

    print(f"{GRN}✓{RST} Generated:")
    print(f"  {KEYMAP_DIR}/keymap.c")
    print(f"  {KEYMAP_DIR}/config.h")
    print(f"  {KEYMAP_DIR}/rules.mk")


