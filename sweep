    for i, lay in enumerate(layers):
        color = LAYER_COLORS[i % len(LAYER_COLORS)]
        desc  = lay.get("description", "")
        print(f"  {color}{BOLD}{i}{RST}  {color}{lay['name']:<8}{RST}  {DIM}{desc}{RST}")
    print()


def cmd_show(args):
    layout = load()
    layers = layout["layers"]
    total  = len(layers)

    if args.layer is not None:
        idx, lay = find_layer(layout, args.layer)
        print(render_layer(lay, idx, total, layers))
    else:
        for i, lay in enumerate(layers):
            print(render_layer(lay, i, total, layers))


def cmd_set(args):
    layout = load()
    _, lay = find_layer(layout, args.layer)

    row = int(args.row)
    col = int(args.col)

    if row < 0 or row > 3:
        sys.exit("ROW must be 0-3 (0=top, 1=home, 2=bottom, 3=thumbs)")

    rows = lay["rows"]
    if row >= len(rows):
        sys.exit(f"Layer {lay['name']} only has {len(rows)} rows")

    max_col = 3 if row == 3 else 9
    if col < 0 or col > max_col:
        sys.exit(f"COL for row {row} must be 0-{max_col}")

    old = rows[row][col]
    rows[row][col] = args.keycode

    print(f"{GRN}✓{RST} {lay['name']}  row {row}  col {col}:  {DIM}{old}{RST}  →  {BOLD}{args.keycode}{RST}")
    save(layout)


def cmd_note(args):
    layout = load()
    _, lay = find_layer(layout, args.layer)
    lay["description"] = args.text
    print(f"{GRN}✓{RST} {lay['name']} description updated")
    save(layout)


def cmd_combos(args):
    layout = load()
