NO_COLOR = not sys.stdout.isatty() or os.environ.get("NO_COLOR")


def _c(*codes):
    if NO_COLOR:
        return ""
    return "\033[" + ";".join(str(c) for c in codes) + "m"


RST  = _c(0)
BOLD = _c(1)
DIM  = _c(2)
