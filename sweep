        result = BYEL + parse_key(c["result"])["tap"] + RST
        desc   = c.get("description", "")
        print(f"  {DIM}{i}{RST}  {keys_disp}  ->  {result}  {DIM}{desc}{RST}")
    print()


def cmd_generate(args):
    layout = load()
    generate_keymap(layout)


def cmd_flash(args):
    """Compile and flash using QMK CLI."""
    layout  = load()
    kb      = layout["meta"]["keyboard"]
    km_path = str(KEYMAP_DIR)

    # Try to find qmk
    qmk = "qmk"
    if subprocess.run(["which", qmk], capture_output=True).returncode != 0:
        sys.exit(
            f"{RED}✗{RST} qmk not found. Install with:\n"
            "  yay -S qmk\n"
            "  or follow https://docs.qmk.fm/#/newbs_getting_started"
        )

    # First generate fresh files
    generate_keymap(layout)

    # Copy keymap files to QMK submodule
    import shutil
    qmk_keymap_dir = Path("./qmk_firmware/keyboards/holykeebs/sweeq/keymaps/sweeq")
    qmk_keymap_dir.mkdir(parents=True, exist_ok=True)
    for f in ["keymap.c", "config.h", "rules.mk"]:
        shutil.copy(KEYMAP_DIR / f, qmk_keymap_dir / f)
    print(f"{GRN}✓{RST} Copied keymap files to QMK submodule")

    print(f"\n{BOLD}Flashing {kb}…{RST}")
    print(f"{DIM}Put keyboard in bootloader mode (QK_BOOT key or double-tap reset){RST}\n")

    # Build using holykeebs fork (hk-master branch) with trackpoint support
    make_args = [
        "make", f"{kb}:sweeq:flash",
        "-e", "USER_NAME=holykeebs",
        "-e", "POINTING_DEVICE=trackpoint",
        "-e", "POINTING_DEVICE_POSITION=right",
        "-j8",
    ]

    # Mount RPI-RP2 drive if in bootloader mode
    subprocess.run(["udisksctl", "mount", "-b", "/dev/sda1"], capture_output=True)

    result = subprocess.run(make_args, cwd="./qmk_firmware")
    if result.returncode != 0:
        sys.exit(f"\n{RED}✗{RST} Flash failed (exit {result.returncode})")
    print(f"\n{GRN}✓{RST} Flash complete!")
    print(f"\n{YEL}⚠{RST} Remember to flash the other half too (same firmware, separate bootloader)")


def cmd_cheatsheet(args):
    """Full cheat sheet -- used by Omarchy popup (sweep cheatsheet)."""
    layout = load()
    layers = layout["layers"]
    combos = layout.get("combos", [])
    total  = len(layers)
    W = 61

    # Header
    print(f"{BCYN}{BOLD}  Sweeq Cheat Sheet{RST}  {DIM}{layout['meta']['description']}{RST}")

    for i, lay in enumerate(layers):
        print(render_layer(lay, i, total, layers))

    # Combos
    if combos:
        print(f"{BYEL}{'-' * W}{RST}")
        print(f"  {BYEL}{BOLD}COMBOS{RST}")
        for c in combos:
            keys_disp = " + ".join(
                CYN + parse_key(k)["tap"] + RST for k in c["keys"]
            )
            res = BGRN + parse_key(c["result"])["tap"] + RST
            desc = c.get("description", "")
            print(f"  {keys_disp} -> {res}  {DIM}{desc}{RST}")

    # Compact legend
    print(f"{DIM}{'-' * W}{RST}")
    print(f"  {CYN}A/Ctl{RST} tap=A hold=Ctrl (HRM)   {BGRN}Bsp/LOW{RST} tap=Bsp hold=layer")
    print(f"  {DIM}___{RST} transparent   {DIM}{RED}---{RST} blocked   Boot=flash   Sup=Super")
    print(f"  MB1-5=mouse btns   Slw/Med=mouse accel   CpWd=caps word")
    print(f"{DIM}  q to close{RST}")

    # Keep window open until user dismisses
    try:
        import tty, termios
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            while True:
                ch = sys.stdin.read(1)
                if ch in ('q', 'Q', '\x03'):  # q or Ctrl+C
                    break
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
    except (ImportError, termios.error, OSError):
        input()


